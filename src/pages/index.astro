  <!-- Navbar & Tabs Scripts -->
  <script>
    // Tab switching logic
    const tabBtns = document.querySelectorAll('.budget-tab-btn');
    const contents = document.querySelectorAll('.budget-content');

    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = btn.getAttribute('data-target');

        // Remove active class from all buttons
        tabBtns.forEach(b => {
          b.classList.remove('active-tab', 'bg-white', 'border-ocean', 'border-emerald', 'border-sunset');
        });

        // Add active class to clicked button
        btn.classList.add('active-tab', 'bg-white');
        const colorClass = targetId === 'kja' ? 'border-ocean' : targetId === 'aquaponik' ? 'border-emerald' : 'border-sunset';
        btn.classList.add(colorClass);

        // Hide all contents
        contents.forEach(content => {
          content.classList.add('hidden', 'opacity-0', 'translate-y-4');
          content.classList.remove('block', 'opacity-100', 'translate-y-0');
        });

        // Show target content
        const targetContent = document.getElementById(`content-${targetId}`);
        if (targetContent) {
          targetContent.classList.remove('hidden');
          // Small timeout to trigger animation
          setTimeout(() => {
            targetContent.classList.add('block', 'opacity-100', 'translate-y-0');
            targetContent.classList.remove('translate-y-4');
          }, 10);
        }
      });
    });

    // Navbar scroll behavior
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 20) {
        navbar?.classList.add('bg-white/95', 'backdrop-blur-md', 'shadow-lg', 'shadow-slate-200/50');
      } else {
        navbar?.classList.remove('bg-white/95', 'backdrop-blur-md', 'shadow-lg', 'shadow-slate-200/50');
      }
    });
  </script>

