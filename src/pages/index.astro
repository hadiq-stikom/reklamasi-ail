---
import Layout from '../layouts/Layout.astro';

const pillars = [
  {
    id: 'kja',
    icon: '🐟',
    label: 'Pilar 01',
    title: 'Perikanan KJA',
    subtitle: 'Keramba Jaring Apung',
    description:
      'Instalasi KJA berukuran 5m × 10m dengan kapasitas produksi 2.000 ekor Ikan Nila unggul. Menggunakan sistem pelampung bambu yang ekonomis dan ramah lingkungan.',
    specs: [
      { label: 'Luas KJA', value: '5m × 10m' },
      { label: 'Kapasitas', value: '2.000 ekor' },
      { label: 'Komoditas', value: 'Ikan Nila' },
      { label: 'Siklus Panen', value: '5–6 bulan' },
    ],
    image: '/images/fish-kja.png',
    color: 'from-ocean to-ocean-light',
    accent: 'ocean',
  },
  {
    id: 'aquaponik',
    icon: '🥬',
    label: 'Pilar 02',
    title: 'Aquaponik Selada',
    subtitle: 'Sistem Rakit Apung',
    description:
      'Sistem rakit apung (DWC) terintegrasi dengan kolam ikan. Target Harga Jual: Rp 25.000 / kg dengan estimasi panen setiap 30–35 hari.',
    specs: [
      { label: 'Lubang Tanam', value: '1.000 unit' },
      { label: 'Komoditas', value: 'Selada Organik' },
      { label: 'Sistem', value: 'Rakit Apung (DWC)' },
      { label: 'Panen', value: '30–35 hari' },
    ],
    image: '/images/aquaponics-price.png',
    color: 'from-emerald to-emerald-light',
    accent: 'emerald',
  },
  {
    id: 'bebek',
    icon: '🥚',
    label: 'Pilar 03',
    title: 'Bebek Petelur',
    subtitle: 'Produksi Telur Harian',
    description:
      '100 ekor bebek petelur produktif terintegrasi dengan ekosistem KJA. Kotoran bebek berfungsi ganda sebagai pakan alami ikan, menciptakan siklus nutrisi zero-waste yang efisien.',
    specs: [
      { label: 'Populasi', value: '100 ekor' },
      { label: 'Produksi', value: '70–80 telur/hari' },
      { label: 'Integrasi', value: 'Bio-siklus KJA' },
      { label: 'Nilai Jual', value: 'Rp 2.000/butir' },
    ],
    image: '/images/duck-farm.png',
    color: 'from-sunset to-sunset-light',
    accent: 'sunset',
  },
];

const team = [
  {
    name: 'Aqib Masud',
    role: 'Ketua Tim',
    bio: 'Mengkoordinasi seluruh lini operasional dan komunikasi strategis dengan stakeholder.',
    image: '/images/aqib.png'
  },
  {
    name: 'Hadiq',
    role: 'Divisi Manajemen & Teknologi',
    bio: 'Optimasi sistem monitoring digital dan efisiensi manajemen basis data proyek.',
    image: '/images/hadiq.png'
  },
  {
    name: 'Moh. Azizi',
    role: 'Divisi Bebek Petelur',
    bio: 'Bertanggung jawab penuh atas produktivitas and kesehatan 100+ populasi bebek.',
    image: '/images/azizi.png'
  },
  {
    name: 'Sufyan',
    role: 'Divisi Keramba Apung',
    bio: 'Ahli teknis dalam instalasi KJA and pembesaran komoditas perikanan air tawar.',
    image: '/images/sufyan.png'
  },
  {
    name: 'Zaim',
    role: 'Divisi Selada',
    bio: 'Spesialis sistem Aquaponik (DWC) untuk memastikan kualitas sayuran organik premium.',
    image: '/images/zaim.png'
  },
  {
    name: 'Anton Al Muqsith',
    role: 'Divisi Pemasaran',
    bio: 'Menjamin serapan hasil panen ke pasar komersial and menjaga siklus kas operasional.',
    image: '/images/anton.png'
  },
  {
    name: 'Somad',
    role: 'Divisi Humas',
    bio: 'Menjaga hubungan harmonis dengan masyarakat sekitar dan pemangku kepentingan lokal.',
    image: '/images/somad.png'
  },
];

const sustainabilityItems = [
  { icon: '🌱', title: 'Optimalisasi Aset', desc: 'Transformasi area bekas galian menjadi kawasan produktif yang terawat dan hijau.' },
  { icon: '🔄', title: 'Mandiri Finansial', desc: 'Siklus operasional yang sehat untuk mendukung perawatan lahan secara mandiri.' },
  { icon: '🌳', title: 'Pemulihan Ekosistem', desc: 'Mengembalikan kesuburan air dan tanah melalui metode integrasi alam.' },
];

const biayaItems = [
  {
    no: 1,
    item: 'Rumah Apung (Sederhana)',
    detail: 'Fondasi tong plastik, bambu, & atap sirap',
    biaya: 'Rp 7.500.000',
    persen: 15.5,
  },
  {
    no: 2,
    item: 'Keramba Jaring Apung (5m x 10m)',
    detail: 'Rangka bambu, jaring, & pelampung',
    biaya: 'Rp 8.000.000',
    persen: 16.5,
  },
  {
    no: 3,
    item: 'Aquaponik Selada (1.000 Lubang)',
    detail: 'Sistem rakit, media tanam, bibit',
    biaya: 'Rp 7.000.000',
    persen: 14.4,
  },
  {
    no: 4,
    item: 'Kandang Bebek Petelur',
    detail: 'Konstruksi bambu, DOD, & pakan awal',
    biaya: 'Rp 9.000.000',
    persen: 18.6,
  },
  {
    no: 5,
    item: 'Operasional & Benih Ikan',
    detail: 'Benih nila, pakan, & cadangan awal',
    biaya: 'Rp 17.000.000',
    persen: 35.0,
  },
];

const budgetTabs = [
  {
    id: 'kja',
    label: 'Program KJA',
    title: 'Keramba Jaring Apung (KJA)',
    description: 'Fokus pada pembesaran ikan (Nila/Mas) dengan struktur pelampung yang kokoh dan perlindungan predator yang maksimal.',
    color: 'ocean',
    items: [
      { activity: 'Rangka Bambu Petung', cost: 'Rp 3.500.000', detail: 'Material lokal yang tahan air (treatment khusus)' },
      { activity: 'Pelampung (Drum Plastik)', cost: 'Rp 2.500.000', detail: 'Drum bekas 200L rasion 1:1' },
      { activity: 'Jaring (Net) Nilon Ganda', cost: 'Rp 1.000.000', detail: 'Tahan gesekan untuk 1 unit 5x10m' },
      { activity: 'Bibit Nila (5-7 cm)', cost: 'Rp 1.000.000', detail: 'Target 2.000 ekor' },
      { activity: 'Pakan Ikan (Grow-out)', cost: 'Rp 12.000 / kg', detail: 'Kebutuhan masa pembesaran 4-6 bulan' },
      { activity: 'Peralatan Aerasi & Pompa', cost: 'Rp 3.500.000', detail: 'Sistem suplay oksigen terintegrasi' },
    ]
  },
  {
    id: 'aquaponik',
    label: 'Aquaponik',
    title: 'Program Aquaponik Selada',
    description: 'Sistem rakit apung (DWC) terintegrasi dengan kolam ikan. Target Harga Jual: Rp 25.000 / kg.',
    color: 'emerald',
    items: [
      { activity: 'Benih Selada (Pelleted)', cost: 'Rp 1.500.000', detail: 'Benih unggul untuk 1.000 titik tanam' },
      { activity: 'Media Tanam (Rockwool/Netpot)', cost: 'Rp 1.000.000', detail: 'Media semai & wadah standar' },
      { activity: 'Modul Rakit Styrofoam HD', cost: 'Rp 3.500.000', detail: 'Modul apung kapasitas 1.000 lubang' },
      { activity: 'Nutrisi & Pompa Sirkulasi', cost: 'Rp 1.000.000', detail: 'Booster nutrisi organik & daya aerasi' },
    ]
  },
  {
    id: 'bebek',
    label: 'Bebek Petelur',
    title: 'Program Telur (Layer Hen System)',
    description: 'Target harga jual Rp 2.000/butir. Target biaya produksi Rp 1.400 - Rp 1.600/butir, sangat dipengaruhi oleh efisiensi pakan (70% total biaya).',
    color: 'sunset',
    items: [
      { activity: 'Bibit Bebek (DOD Unggul)', cost: 'Rp 3.500.000', detail: '100 ekor bebek petelur produktif' },
      { activity: 'Konstruksi Kandang Bambu', cost: 'Rp 2.500.000', detail: 'Kandang lay-out di area KJA' },
      { activity: 'Pakan Awal & Vitamin', cost: 'Rp 2.000.000', detail: 'Nutrisi masa adaptasi 1-2 bulan' },
      { activity: 'Peralatan Makan & Minum', cost: 'Rp 1.000.000', detail: 'Sistem otomatis sederhana' },
    ]
  },
  {
    id: 'rumahapung',
    label: 'Rumah Apung',
    title: 'Pusat Kontrol & Rumah Apung',
    description: 'Penyediaan fasilitas monitoring 24/7 dan gudang logistik pakan di lokasi strategis tengah kolam.',
    color: 'ocean',
    items: [
      { activity: 'Konstruksi Rangka Bambu', cost: 'Rp 2.500.000', detail: 'Penopang utama 1 lantai' },
      { activity: 'Tong Plastik (Pelampung)', cost: 'Rp 2.500.000', detail: 'Kapasitas apung aman 2 orang' },
      { activity: 'Atap Sirap & Dinding', cost: 'Rp 1.500.000', detail: 'Material ringan dan estetik' },
      { activity: 'Instalasi Solar Small', cost: 'Rp 1.000.000', detail: 'Kebutuhan penerangan bertenaga surya' },
    ]
  }
];

const stats = [
  { value: '10 Ha', label: 'Total Lahan Galian C' },
  { value: '4 Ha', label: 'Area Percontohan' },
  { value: '3', label: 'Pilar Usaha Utama' },
  { value: 'Rp 48.5 Jt', label: 'Total Investasi' },
];
---

<Layout>
  <header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
    <nav class="max-w-7xl mx-auto px-5 py-4 flex items-center">
      <!-- Logo -->
      <div class="flex-1"><a href="#hero" class="flex items-center gap-2.5 group">
        <div class="w-9 h-9 rounded-xl bg-linear-to-br from-ocean to-emerald flex items-center justify-center text-white font-bold text-sm shadow-lg group-hover:scale-110 transition-transform">
          TDA
        </div>
        <span class="font-heading font-700 text-ocean text-sm leading-tight hidden sm:block">
          TriDharma<br /><span class="text-emerald">Agro</span>
        </span>
      </a></div>

      <!-- Nav Links -->
      <div class="flex items-center gap-4 sm:gap-7 flex-none overflow-x-auto no-scrollbar py-1">
        {['Visi', 'Pilar', 'Kontrol', 'Investasi', 'Anggaran'].map((item) => (
          <a
            href={`#${item.toLowerCase()}`}
            class="nav-link text-xs sm:text-sm font-medium text-slate-600 hover:text-ocean whitespace-nowrap"
          >
            {item}
          </a>
        ))}
      </div>
      <div class="flex-1"></div>
    </nav>
  </header>

  <!-- ═══════════════════════════════ HERO ═══════════════════════════════ -->
  <section
    id="hero"
    class="relative min-h-screen flex items-center justify-center overflow-hidden"
  >
    <!-- Background image with overlay -->
    <div class="absolute inset-0 z-0">
      <img
        src="/images/hero.png"
        alt="Aerial view of integrated aquaponics lake farm"
        class="w-full h-full object-cover object-center"
      />
      <div class="absolute inset-0 bg-linear-to-b from-ocean/80 via-ocean-dark/70 to-emerald-dark/85"></div>
      <!-- Animated particle overlay -->
      <div class="absolute inset-0 bg-[url('/images/hero.png')] opacity-5 bg-repeat blur-2xl scale-110"></div>
    </div>

    <!-- Decorative circles -->
    <div class="absolute top-1/4 right-10 w-80 h-80 rounded-full border border-white/10 animate-pulse opacity-30 hidden lg:block"></div>
    <div class="absolute top-1/3 right-16 w-48 h-48 rounded-full border border-white/10 animate-pulse opacity-20 hidden lg:block [animation-delay:1s]"></div>

    <!-- Content -->
    <div class="relative z-10 max-w-5xl mx-auto px-5 text-center py-32">
      <!-- Eyebrow badge -->
      <div class="animate-float inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 text-white/90 text-xs font-semibold tracking-widest uppercase rounded-full px-5 py-2 mb-8">
        <span class="w-2 h-2 rounded-full bg-leaf animate-pulse"></span>
        Proposal Reklamasi Galian C Tahap 1 · 2026
      </div>

      <h1 class="animate-float-delay-1 font-heading text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold text-white leading-[1.1] tracking-tight mb-6">
        Restorasi Aktif Lahan:<br />
        <span class="bg-linear-to-r from-leaf to-sky bg-clip-text text-transparent">
          Solusi Produktif Pasca Tambang
        </span>
      </h1>

      <p class="animate-float-delay-2 text-lg md:text-xl text-white/75 max-w-2xl mx-auto leading-relaxed mb-10">
        Memastikan lahan <span class="text-white font-semibold">Bekas Galian C</span> tetap produktif, hijau, dan terawat .
      </p>

      <div class="animate-float-delay-3 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="#pilar"
          id="cta-hero"
          class="btn-primary text-white font-semibold px-8 py-4 rounded-full text-base shadow-xl inline-flex items-center gap-2"
        >
          Lihat Rencana Proyek
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
        <a
          href="#investasi"
          class="text-white/80 hover:text-white font-medium px-6 py-4 rounded-full border border-white/20 hover:border-white/40 transition-all text-base inline-flex items-center gap-2"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
          Rincian Investasi
        </a>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-60">
        <span class="text-white/60 text-xs tracking-widest uppercase">Gulir ke bawah</span>
        <div class="w-5 h-9 border-2 border-white/30 rounded-full flex justify-center pt-1.5">
          <div class="w-1 h-2 bg-white/60 rounded-full animate-bounce"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════ STATS BAR ═══════════════════════════ -->
  <section class="bg-ocean py-8">
    <div class="max-w-5xl mx-auto px-5 grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      {stats.map((s, i) => (
        <div class="reveal" style={`transition-delay: ${i * 100}ms`}>
          <div class="text-3xl md:text-4xl font-heading font-extrabold text-white">{s.value}</div>
          <div class="text-white/60 text-sm mt-1">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════ VISI ═══════════════════════════════ -->
  <section id="visi" class="py-24 bg-white">
    <div class="max-w-6xl mx-auto px-5">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Text -->
        <div class="reveal">
          <div class="section-badge">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
            Visi Proyek
          </div>
          <h2 class="font-heading text-4xl md:text-5xl font-bold text-ocean-dark mb-6 leading-tight">
            Menghidupkan Lahan,<br />
            <span class="text-emerald">Meningkatkan Nilai Kawasan</span>
          </h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Lahan pasca-tambang Galian C seluas 10 hektar memiliki potensi besar yang melampaui sekadar area kosong. Dengan manajemen yang tepat, zona timur seluas 4 hektar kini dikelola aktif sebagai area percontohan.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed mb-8">
            Melalui integrasi perikanan, pertanian, dan peternakan, kami memastikan adanya **keberlanjutan ekosistem dan aktivitas produksi** yang kontinyu. Ini adalah langkah nyata untuk menjaga kesuburan lahan agar tetap hijau, produktif, dan bermanfaat bagi lingkungan sekitar.
          </p>

          <div class="grid grid-cols-2 gap-4">
            {[
              { icon: '💧', label: 'Sumber Air Bersih', desc: 'Debit stabil sepanjang tahun' },
              { icon: '🌿', label: 'Lahan 4 Hektar', desc: 'Area pilot project terpilih' },
              { icon: '♻️', label: 'Zero-Waste Cycle', desc: 'Integrasi nutrisi antar pilar' },
              { icon: '📈', label: 'Skalabel', desc: 'Model replikasi ke zona barat' },
            ].map((item) => (
              <div class="stat-card bg-slate-50 rounded-2xl p-5 pl-7">
                <div class="text-2xl mb-2">{item.icon}</div>
                <div class="font-heading font-semibold text-ocean-dark text-sm">{item.label}</div>
                <div class="text-slate-500 text-xs mt-0.5">{item.desc}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Visual map/illustration -->
        <div class="reveal relative">
          <div class="relative rounded-3xl overflow-hidden shadow-2xl shadow-ocean/15">
            <img
              src="/images/hero.png"
              alt="Aerial view of the integrated farm"
              class="w-full h-[480px] object-cover object-top"
            />
            <div class="absolute inset-0 bg-linear-to-t from-ocean-dark/60 via-transparent to-transparent"></div>

            <!-- Info overlay -->
            <div class="absolute bottom-6 left-6 right-6">
              <div class="glass-card rounded-2xl p-5 text-white">
                <div class="flex items-center gap-3 mb-3">
                  <div class="w-3 h-3 rounded-full bg-leaf animate-pulse"></div>
                  <span class="font-semibold text-sm">Zona Timur — Area Aktif</span>
                </div>
                <div class="grid grid-cols-3 gap-3 text-center">
                  {[['4 Ha', 'Area'], ['Bersih', 'Kualitas Air'], ['Stabil', 'Debit']].map(([val, lbl]) => (
                    <div>
                      <div class="font-heading font-bold text-sky text-lg">{val}</div>
                      <div class="text-white/60 text-xs">{lbl}</div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>

          <!-- Floating badge -->
          <div class="absolute -top-5 -right-5 bg-ocean text-white rounded-2xl px-5 py-3 shadow-xl font-heading font-bold text-sm">
            🏆 Pilot Project<br />
            <span class="text-leaf">2026</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════ 3 PILLARS ════════════════════════════ -->
  <section id="pilar" class="py-24 bg-slate-50">
    <div class="max-w-7xl mx-auto px-5">
      <div class="text-center mb-16 reveal">
        <div class="section-badge inline-flex mx-auto">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>
          Layout Proyek
        </div>
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-ocean-dark mt-2">
          3 Pilar Utama Ekosistem Biru
        </h2>
        <p class="text-slate-500 text-lg mt-4 max-w-2xl mx-auto">
          Tiga unit produksi yang saling terintegrasi, menciptakan siklus ekonomi yang efisien dan berkelanjutan dalam satu ekosistem.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {pillars.map((p, i) => (
          <div
            class="pillar-card reveal bg-white rounded-3xl overflow-hidden shadow-lg shadow-slate-200/80 flex flex-col"
            style={`transition-delay: ${i * 150}ms`}
          >
            <!-- Card image -->
            <div class="relative h-52 overflow-hidden">
              <img
                src={p.image}
                alt={p.title}
                class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
              />
              <div class={`absolute inset-0 bg-linear-to-t ${p.color} opacity-60`}></div>
              <div class="absolute top-4 left-4">
                <span class="bg-white/20 backdrop-blur-sm text-white text-xs font-bold tracking-widest uppercase px-3 py-1 rounded-full border border-white/30">
                  {p.label}
                </span>
              </div>
              <div class="absolute bottom-4 left-4">
                <div class="text-3xl mb-1">{p.icon}</div>
                <h3 class="font-heading font-bold text-white text-xl leading-tight">{p.title}</h3>
                <p class="text-white/70 text-xs">{p.subtitle}</p>
              </div>
            </div>

            <!-- Card body -->
            <div class="p-6 flex flex-col flex-1">
              <p class="text-slate-600 text-sm leading-relaxed mb-6">
                {p.description}
              </p>

              <!-- Specs grid -->
              <div class="grid grid-cols-2 gap-3 mt-auto">
                {p.specs.map((spec) => (
                  <div class="bg-slate-50 rounded-xl p-3">
                    <div class="text-[10px] text-slate-400 font-semibold uppercase tracking-wider mb-0.5">{spec.label}</div>
                    <div class="font-heading font-bold text-ocean-dark text-sm">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Card footer accent -->
            <div class={`h-1 bg-linear-to-r ${p.color}`}></div>
          </div>
        ))}
      </div>

      <!-- Integration diagram note -->
      <div class="reveal mt-12 bg-linear-to-r from-ocean/5 to-emerald/5 border border-ocean/10 rounded-2xl p-6 text-center">
        <p class="text-slate-600 text-sm md:text-base">
          <span class="font-semibold text-ocean">💡 Sinergi Terintegrasi:</span>
          Kotoran bebek → Nutrisi Ikan → Limbah Ikan → Bio-filter Aquaponik → Selada Segar.
          Satu sistem, tiga sumber pendapatan, nol pemborosan.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════ RUMAH APUNG ══════════════════════════ -->
  <section id="kontrol" class="py-24 bg-white overflow-hidden">
    <div class="max-w-6xl mx-auto px-5">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Image side -->
        <div class="reveal order-2 lg:order-1 relative">
          <div class="rounded-3xl overflow-hidden shadow-2xl shadow-ocean/20 relative">
            <img
              src="/images/floating-house.png"
              alt="Rumah Apung pusat monitoring"
              class="w-full h-[500px] object-cover"
            />
